<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title></title>
    <link rel="stylesheet" href="/css/style.css" />
    <!-- Load Google Material Symbols -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet">
</head>

<body>
    <nav>
        <ul class="Navigation">
            <div class="left-nav">
                <li>
                    
                    <a href="Homepage.html"><img class= "JobFindLogo" src="~/images/jobfind_logo.png" /></a>
                </li>
                <li>
                    <a href="JobHistoryPage.html">Job History</a>
                </li>
                <li>Online Resume</li>
                <li>Chat</li>
                <li>Register</li>
            </div>
            <div class="right-nav">
                <li class="searchBar">
                    <span class="search-icon material-symbols-outlined">search</span>
                    <input class="search-input" type="search" placeholder="Search" />
                </li>
                <li class="notification">
                    <button class="notification-icon material-symbols-outlined">notifications</button>
                    <ul class="dropdown">
                        <li>unread messages</li>
                        <li>unread messages</li>
                        <li>unread messages</li>
                    </ul>
                </li>
                <li class="account">
                    <button class="account-icon material-symbols-outlined">account_circle</button>
                    <ul class="dropdown">
                        <li>Profile</li>
                        <li>Settings</li>
                        <li>Logout/Login</li>
                    </ul>
                </li>
            </ul>
        </div>
    </nav>

    <main class="container">
        @RenderBody()
    </main>
</body>
</html>