<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title - JobFind</title>

    @* Shared CSS — loaded on every page *@
    <link rel="stylesheet" href="~/css/StyleSheet.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/validation.css" asp-append-version="true" />

    @* Page-specific CSS — each view injects its own *@
    @RenderSection("Styles", required: false)

    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet">
</head>
<body>

    @{
        string navSearch = Context.Request.Query["search"].ToString();
        string navUserType = Context.Session.GetString("UserTypeID");
        // Employees and guests both search the open job catalog.
        string navSearchAction = (navUserType == "2" || navUserType == null) ? "/Employee/JobCatalog" : "/Guest/Home";
    }

    @* Nav is here once — every page gets it automatically *@
    <nav>
        <ul class="Navigation">
            <li class="logo-item">
                <a href="/Guest/Home">
                    <img class="JobFindLogo" src="~/images/JobFind_Logo.png" alt="JobFind logo" />
                </a>
            </li>

            @* Show nav links based on who is logged in *@
            @if (Context.Session.GetString("UserTypeID") == "2")
            {
                @* Employee nav (UserTypeID = 2) *@
                <li><a href="/Employee/JobHistory">Job History</a></li>
                <li><a href="/Employee/JobCatalog">Job Catalog</a></li>
                <li><a href="/Employee/SavedJobs">Saved Jobs</a></li>
                <li><a href="/Employee/Resume">Online Resume</a></li>
                <li><a href="/Employee/Chat">Chat</a></li>
            }
            else if (Context.Session.GetString("UserTypeID") == "3")
            {
                @* Employer nav (UserTypeID = 3) *@
                <li><a href="/Employer/YourJobs">Your Jobs</a></li>
                <li><a href="/Employer/PostJob">Post a Job</a></li>
                <li><a href="/Employer/HiredCandidates">Hired</a></li>
                <li><a href="/Employer/Chat">Chat</a></li>
            }
            else if (Context.Session.GetString("UserTypeID") == "4")
            {
                @* Admin nav (UserTypeID = 4) *@
                <li><a href="/Admin/Home">Manage Jobs</a></li>
                <li><a href="/Admin/Applications">Applications</a></li>
                <li><a href="/Admin/Notify">Notify Users</a></li>
                <li><a href="/Admin/Reports">Reports</a></li>
            }
            else
            {
                @* Guest nav *@
                <li><a href="/Employee/JobCatalog">Browse Jobs</a></li>
                <li><a href="/Guest/Login">Register</a></li>
            }

            @* Search bar — shown to everyone and routes to the right searchable page *@
            <li class="searchBar">
                <form method="get" action="@navSearchAction" class="nav-search-form">
                    <span class="search-icon material-symbols-outlined" aria-hidden="true">search</span>
                    <input class="search-input" name="search" type="search" value="@navSearch" placeholder="Search jobs, companies, or skills" aria-label="Search jobs" />
                </form>
            </li>

            @* Notifications — only for logged in users *@
            @if (Context.Session.GetString("UserID") != null)
            {
                <li class="notification" style="position:relative;">
                    <button class="notification-icon material-symbols-outlined" aria-label="Notifications">notifications</button>
                    <span id="notif-badge" style="display:none;position:absolute;top:0;right:0;min-width:16px;height:16px;padding:0 4px;background:#e02424;color:#fff;border-radius:999px;font-size:0.64rem;font-weight:700;line-height:16px;text-align:center;pointer-events:none;">0</span>
                    @* Capped to ~4 rows; the rest scroll. *@
                    <ul class="dropdown" id="notification-dropdown" style="max-height:264px;overflow-y:auto;">
                        <li>Loading...</li>
                    </ul>
                </li>
            }

            @* Account dropdown *@
            <li class="account">
                <button class="account-icon material-symbols-outlined" aria-label="Account menu">account_circle</button>
                <ul class="dropdown">
                    @if (Context.Session.GetString("UserID") != null)
                    {
                        <li><a href="/@(Context.Session.GetString("UserTypeID") == "2" ? "Employee" : Context.Session.GetString("UserTypeID") == "3" ? "Employer" : "Admin")/Profile">Profile</a></li>
                        <li><a href="/Guest/Logout">Logout</a></li>
                    }
                    else
                    {
                        <li><a href="/Guest/Login?tab=signin">Login</a></li>
                        <li><a href="/Guest/Login">Register</a></li>
                    }
                </ul>
            </li>
        </ul>
    </nav>

    @* Page content goes here — each view fills this in *@
    @RenderBody()

    @* ── Delete Job Confirmation Modal (shared across all pages) ── *@
    <div id="delete-confirm-modal" class="modal-container" aria-hidden="true">
        <div class="modal-overlay"></div>
        <div class="modal-dialog">
            <div class="modal-icon">
                <span class="material-symbols-outlined">warning</span>
            </div>
            <h2>Delete Job?</h2>
            <p>Are you sure you want to permanently delete <strong class="modal-job-title">this job</strong>? This action cannot be undone.</p>
            <div class="modal-actions">
                <button type="button" class="modal-cancel">Cancel</button>
                <button type="button" class="modal-confirm">Yes, Delete</button>
            </div>
        </div>
    </div>

    @* ── Report Modal (logged-in, non-admin users) ── *@
    @if (Context.Session.GetString("UserID") != null && Context.Session.GetString("UserTypeID") != "4")
    {
        <div id="report-modal" class="modal-container" aria-hidden="true">
            <div class="modal-overlay"></div>
            <div class="modal-dialog" style="text-align:left;">
                <h2 style="margin-bottom:4px;">Report <span class="report-target-label">this</span></h2>
                <p style="color:var(--text-500);font-size:0.9rem;margin-bottom:14px;">Sent privately to the admins for review.</p>
                <form method="post" action="/Report/Submit" id="report-form" style="display:grid;gap:12px;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="targetType" value="" />
                    <input type="hidden" name="targetId" value="" />
                    <input type="hidden" name="subject" value="" />
                    <input type="hidden" name="returnUrl" value="" />
                    <label style="display:flex;flex-direction:column;gap:6px;font-size:0.86rem;font-weight:600;color:var(--text-700);">
                        Reason
                        <select name="category" style="font-family:inherit;font-size:0.95rem;font-weight:400;color:var(--text-900);background:var(--surface-2);border:1.5px solid var(--line);border-radius:var(--radius-sm);padding:10px 13px;outline:none;">
                            <option value="" disabled selected>Choose a reason</option>
                            <option value="Offensive content / slurs">Offensive content / slurs</option>
                            <option value="Spam or bot">Spam or bot</option>
                            <option value="Scam or fraud">Scam or fraud</option>
                            <option value="Other">Other</option>
                        </select>
                    </label>
                    <label style="display:flex;flex-direction:column;gap:6px;font-size:0.86rem;font-weight:600;color:var(--text-700);">
                        Details <span style="font-weight:400;color:var(--text-500);">(optional)</span>
                        <textarea name="reportText" rows="3" placeholder="Add any details..." style="font-family:inherit;font-size:0.95rem;font-weight:400;color:var(--text-900);background:var(--surface-2);border:1.5px solid var(--line);border-radius:var(--radius-sm);padding:10px 13px;outline:none;resize:vertical;"></textarea>
                    </label>
                    <div class="modal-actions">
                        <button type="button" class="modal-cancel report-cancel">Cancel</button>
                        <button type="submit" class="modal-confirm">Send Report</button>
                    </div>
                </form>
            </div>
        </div>
    }

    @* Shared JS *@
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/validation.js" asp-append-version="true"></script>
    <script>window.JOBFIND_CURRENCY = '@(Context.Session.GetString("Currency") ?? "USD")';</script>
    <script src="~/js/currency.js" asp-append-version="true"></script>
    <script src="~/js/report.js" asp-append-version="true"></script>

    @* Page-specific JS *@
    @RenderSection("Scripts", required: false)

</body>
</html>