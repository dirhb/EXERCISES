@*
    Views/Employee/Resume.cshtml
    Simplified online resume builder for employees.
    Single textarea for resume/cover letter text.
    Form posts to EmployeeController → UpdateResume
*@

@{
    ViewBag.Title = "Online Resume";
}

@section Styles {
    <link rel="stylesheet" href="~/css/OnlineResume.css" />
}

<header class="page-header content-page-header">
    <h1>Online Resume</h1>
    <p>Write and update your professional summary and cover letter.</p>
</header>

<main class="container content-page resume-page">
    <section class="left-col">
        <div class="card">
            <h3>Resume / Cover Letter</h3>
            @if (!string.IsNullOrEmpty(ViewBag.ResumeText))
            {
                <div style="margin-bottom: 20px; padding: 16px; background: var(--surface-2); border: 1.5px dashed var(--brand-300); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px;">
                    <div>
                        <span style="font-weight: 700; color: var(--brand-800); display: block;">Saved Resume</span>
                        <span style="font-size: 0.85rem; color: var(--text-500);">You already have a resume uploaded.</span>
                    </div>
                    <a href="@ViewBag.ResumeText" target="_blank" class="cta-btn" style="padding: 8px 16px; font-size: 0.88rem; display: inline-flex; align-items: center; gap: 6px; background: var(--brand-600); color: #fff;">
                        <span class="material-symbols-outlined" style="font-size: 18px;">picture_as_pdf</span>
                        View PDF
                    </a>
                </div>
            }

            <form method="post" action="/Employee/UpdateResume" enctype="multipart/form-data" id="resume-upload-form">
                @Html.AntiForgeryToken()
                <div class="acc-fields">
                    <label style="display: block; font-weight: 600; margin-bottom: 8px; color: var(--text-700);">
                        Upload PDF Resume (Max 5MB)
                    </label>
                    <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap; padding:10px; border:1.5px solid var(--line); border-radius:var(--radius-sm); background:var(--surface-2);">
                        <label class="custom-file-label" style="flex-shrink:0;">
                            <span class="material-symbols-outlined" style="font-size:16px;">upload_file</span>
                            Choose PDF
                            <input type="file" id="resume-file-input" name="resumeFile" accept=".pdf" required />
                        </label>
                        <span id="resume-file-name" style="font-size:0.85rem; color:var(--text-500); font-weight:400;">No file chosen</span>
                    </div>
                </div>
                <button type="submit" class="auth-submit" style="margin-top:16px; width: auto; padding: 10px 24px;">Upload Resume</button>
            </form>
        </div>
    </section>

    @section Scripts {
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                const form = document.getElementById('resume-upload-form');
                if (form) {
                    const fileInput = form.querySelector('input[name="resumeFile"]');
                    fileInput.addEventListener('change', () => {
                        const file = fileInput.files[0];
                        if (file) {
                            if (file.type !== 'application/pdf' && !file.name.toLowerCase().endsWith('.pdf')) {
                                alert('Please select a PDF file only.');
                                fileInput.value = '';
                                return;
                            }
                            if (file.size > 5 * 1024 * 1024) {
                                alert('File size exceeds the 5MB limit.');
                                fileInput.value = '';
                                return;
                            }
                        }
                    });
                }
            });
        </script>
    }

    <aside class="right-col">
        <div class="card">
            <h3>Contact Info</h3>
            <ul class="popular-list">
                <li>Email: @ViewBag.Email</li>
                <li>Phone: @ViewBag.PhoneNum</li>
                <li>Location: @ViewBag.CountryName</li>
            </ul>
        </div>
    </aside>
</main>
