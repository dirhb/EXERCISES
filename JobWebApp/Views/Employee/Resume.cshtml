@*
    Views/Employee/Resume.cshtml
    Simplified online resume builder for employees.
    Single textarea for resume/cover letter text.
    Form posts to EmployeeController → UpdateResume
*@

@{
    ViewBag.Title = "Online Resume";
}

@section Styles {
    <link rel="stylesheet" href="~/css/OnlineResume.css" />
}

<header class="page-header content-page-header">
    <h1>Online Resume</h1>
    <p>Write and update your professional summary and cover letter.</p>
</header>

<main class="container content-page resume-page">
    <section class="left-col">
        <div class="card">
            <h3>Resume / Cover Letter</h3>
            <form method="post" action="/Employee/UpdateResume">
                <div class="acc-fields">
                    <label>Online Resume / Cover Letter
                        <textarea name="resumeText" rows="12" placeholder="Write your professional summary, skills, experience, and cover letter text here...">@ViewBag.ResumeText</textarea>
                    </label>
                </div>
                <button type="submit" class="auth-submit" style="margin-top:12px">Save Resume</button>
            </form>
        </div>
    </section>

    <aside class="right-col">
        <div class="card">
            <h3>Contact Info</h3>
            <ul class="popular-list">
                <li>Email: @ViewBag.Email</li>
                <li>Phone: @ViewBag.PhoneNum</li>
                <li>Location: @ViewBag.Country</li>
            </ul>
        </div>
    </aside>
</main>
