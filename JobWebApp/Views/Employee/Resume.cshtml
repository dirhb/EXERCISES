@*
    Views/Employee/Resume.cshtml
    Online resume builder for employees.
    A single text area where the employee writes their resume / cover letter.
    Form posts to EmployeeController → UpdateResume (saved as plain text).
*@

@{
    ViewBag.Title = "Online Resume";
    string resumeText = (ViewBag.ResumeText as string) ?? string.Empty;
}

@section Styles {
    <link rel="stylesheet" href="~/css/OnlineResume.css" />
}

<header class="page-header content-page-header">
    <h1>Online Resume</h1>
    <p>Write and update your professional summary and cover letter.</p>
</header>

<main class="container content-page resume-page">
    <section class="left-col">
        <div class="card">
            <h3>Online Resume</h3>
            <p style="color: var(--text-500); font-size: 0.9rem; margin: -4px 0 16px;">
                Write about your experience, skills and what you're looking for. This is shown to employers when you apply.
            </p>

            <form method="post" asp-action="UpdateResume" asp-controller="Employee" id="resume-form">
                @Html.AntiForgeryToken()
                <div class="acc-fields">
                    <label>
                        Your Resume
                        <textarea name="resumeText" id="resume-text" rows="16"
                                  placeholder="e.g. Front-end developer with 3 years of experience building responsive web apps with React and TypeScript...">@resumeText</textarea>
                    </label>
                </div>
                <div style="display:flex; align-items:center; justify-content:space-between; gap:12px; margin-top:16px; flex-wrap:wrap;">
                    <span id="char-count" style="font-size:0.82rem; color:var(--text-500);">@resumeText.Length characters</span>
                    <button type="submit" class="auth-submit" style="width:auto; padding:10px 24px;">Save Resume</button>
                </div>
            </form>
        </div>
    </section>

    <aside class="right-col">
        <div class="card">
            <h3>Contact Info</h3>
            <ul class="popular-list">
                <li>Email: @ViewBag.Email</li>
                <li>Phone: @ViewBag.PhoneNum</li>
                <li>Location: @ViewBag.CountryName</li>
            </ul>
        </div>
    </aside>
</main>

@if (TempData["Success"] != null)
{
    <div class="toast-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="toast-error">@TempData["Error"]</div>
}

@section Scripts {
    <script>
        // Live character count under the resume box.
        document.addEventListener('DOMContentLoaded', () => {
            const box = document.getElementById('resume-text');
            const count = document.getElementById('char-count');
            if (box && count) {
                box.addEventListener('input', () => {
                    count.textContent = box.value.length + ' characters';
                });
            }
        });
    </script>
}
