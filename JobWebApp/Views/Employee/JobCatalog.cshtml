@*
    Views/Employee/JobCatalog.cshtml
    Employee job catalog with search, employer and genre filters, and pagination.
*@

@using JobModels
@{
    ViewBag.Title = "Job Catalog";
    var jobs = ViewBag.Jobs as List<Job> ?? new List<Job>();
    var employers = ViewBag.Employers as List<string> ?? new List<string>();
    // Genres now come from the database as Genre objects with GenreID and GenreTitle
    var genres = ViewBag.Genres as List<Genre> ?? new List<Genre>();
    string search = ViewBag.Search as string ?? string.Empty;
    string selectedEmployer = ViewBag.SelectedEmployer as string ?? string.Empty;
    string selectedGenre = ViewBag.SelectedGenre as string ?? string.Empty;
    string selectedJobType = ViewBag.SelectedJobType as string ?? string.Empty;
    bool showActiveOnly = ViewBag.ShowActiveOnly == true;
    string minSalary = ViewBag.MinSalary != null ? ViewBag.MinSalary.ToString() : string.Empty;
    string maxSalary = ViewBag.MaxSalary != null ? ViewBag.MaxSalary.ToString() : string.Empty;
    int page = Convert.ToInt32(ViewBag.Page ?? 1);
    int totalPages = Convert.ToInt32(ViewBag.TotalPages ?? 1);
    int totalJobs = Convert.ToInt32(ViewBag.TotalJobs ?? jobs.Count);
    var savedJobIds = ViewBag.SavedJobIds as HashSet<string> ?? new HashSet<string>();

    // Build a catalog URL for a given page, preserving every active filter.
    Func<int, string> pageUrl = p =>
        $"/Employee/JobCatalog?search={Uri.EscapeDataString(search)}" +
        $"&genreId={Uri.EscapeDataString(selectedGenre)}" +
        $"&employerId={Uri.EscapeDataString(selectedEmployer)}" +
        $"&jobType={Uri.EscapeDataString(selectedJobType)}" +
        $"&minSalary={Uri.EscapeDataString(minSalary)}&maxSalary={Uri.EscapeDataString(maxSalary)}" +
        $"&showActiveOnly={(showActiveOnly ? "true" : "false")}&page={p}";
}

@section Styles {
    <link rel="stylesheet" href="~/css/HomePage.css" asp-append-version="true" />
}

<header class="page-header content-page-header catalog-header">
    <h1>Job Catalog</h1>
    <p>Browse every available job, search by keyword, and narrow the list by employer or genre.</p>
</header>

<main class="job-catalog-shell">
    <section class="catalog-main card">
        <form class="catalog-toolbar" method="get" action="/Employee/JobCatalog">
            <label class="catalog-search">
                <span class="material-symbols-outlined" aria-hidden="true">search</span>
                <input type="search" name="search" value="@search" placeholder="Search jobs, companies, locations, or skills" />
            </label>
            <input type="hidden" name="genreId" value="@selectedGenre" />
            <input type="hidden" name="showActiveOnly" value="@(ViewBag.ShowActiveOnly == true ? "true" : "false")" />
            <input type="number" name="minSalary" value="@minSalary" placeholder="Min $" min="0" aria-label="Minimum salary (USD)"
                   style="width:96px;padding:9px 11px;border:1.5px solid var(--line);border-radius:var(--radius-sm);background:var(--surface-2);color:var(--text-900);" />
            <input type="number" name="maxSalary" value="@maxSalary" placeholder="Max $" min="0" aria-label="Maximum salary (USD)"
                   style="width:96px;padding:9px 11px;border:1.5px solid var(--line);border-radius:var(--radius-sm);background:var(--surface-2);color:var(--text-900);" />
            <button type="submit" class="catalog-filter-btn">Search</button>
            <a class="catalog-reset" href="/Employee/JobCatalog">Clear</a>
        </form>

        <div class="catalog-count">
            Showing @jobs.Count of @totalJobs job@(totalJobs == 1 ? string.Empty : "s")
        </div>

        @if (jobs.Any())
        {
            <div class="job-list">
                @foreach (var job in jobs)
                {
                    string returnUrl = Context.Request.Path.ToString() + Context.Request.QueryString.ToString();
                    <article class="job-card-lg">
                        @* Clickable body → individual job page *@
                        <a class="jcl-body" href="/Employee/JobDetails?jobId=@job.JobID">
                            <div class="jcl-head">
                                <div>
                                    <div class="jcl-title">@job.JobTitle</div>
                                    <div class="jcl-company">@(job.EmployerName ?? "JobFind Employer")</div>
                                </div>
                                <div class="jcl-badges">
                                    @if (job.JobStatus == true)
                                    {
                                        <span class="jcl-badge active">Active</span>
                                    }
                                    else
                                    {
                                        <span class="jcl-badge closed">Position Filled</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(job.JobTypeName))
                                    {
                                        <span class="jcl-badge type">@job.JobTypeName</span>
                                    }
                                </div>
                            </div>
                            <div class="jcl-meta-row">
                                <span class="jcl-meta"><span class="material-symbols-outlined" aria-hidden="true">location_on</span>@(job.CountryName ?? "Not specified")</span>
                                @if (!string.IsNullOrWhiteSpace(job.JobTypeName))
                                {
                                    <span class="jcl-meta"><span class="material-symbols-outlined" aria-hidden="true">work</span>@job.JobTypeName</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(job.GenreTitle))
                                {
                                    <span class="jcl-meta"><span class="material-symbols-outlined" aria-hidden="true">category</span>@(job.GenreTitle)</span>
                                }
                                @if (job.Salary.HasValue)
                                {
                                    <span class="jcl-meta"><span class="material-symbols-outlined" aria-hidden="true">payments</span><span class="money" data-usd="@job.Salary.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)">$@job.Salary.Value.ToString("N0")</span></span>
                                }
                            </div>
                            <p class="jcl-desc">@(string.IsNullOrWhiteSpace(job.JobDescription) ? "No description provided yet." : job.JobDescription)</p>
                            @if (!string.IsNullOrWhiteSpace(job.JobFilter))
                            {
                                <div class="jcl-tags"><span>@job.JobFilter</span></div>
                            }
                            <span class="jcl-viewlink">View details →</span>
                        </a>

                        @* Action footer — sits outside the link so buttons stay clickable *@
                        <div class="jcl-actions">
                            @if (Context.Session.GetString("UserTypeID") == "2")
                            {
                                @if (job.JobStatus == false)
                                {
                                    <button type="button" class="catalog-apply-btn" style="background:var(--line); color:var(--text-500); cursor:not-allowed;" disabled>Position Filled</button>
                                }
                                else
                                {
                                    <form method="post" action="/Employee/ApplyToJob" enctype="multipart/form-data" style="display:flex; align-items:center; gap:8px; flex-wrap:wrap; margin:0;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="jobId" value="@job.JobID" />
                                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                                        <label class="custom-file-label">
                                            <span class="material-symbols-outlined" style="font-size:15px;">upload_file</span>
                                            PDF (optional)
                                            <input type="file" name="resumeFile" accept=".pdf" class="custom-apply-file" />
                                        </label>
                                        <span class="custom-file-name" data-default="No file">No file</span>
                                        <button type="submit" class="catalog-apply-btn">Apply Now</button>
                                    </form>
                                }
                                @if (!string.IsNullOrEmpty(job.EmployerID))
                                {
                                    <a href="/Employee/Chat?partnerId=@job.EmployerID" class="cta-btn secondary" style="font-size:0.85rem; padding:7px 16px;">Message</a>
                                }
                                <button type="button" class="report-btn" data-report-type="Job" data-report-id="@job.JobID" data-report-label="@job.JobTitle"
                                        style="background:none;border:none;color:var(--text-500);font-size:0.83rem;cursor:pointer;display:inline-flex;align-items:center;gap:4px;padding:7px 6px;">
                                    <span class="material-symbols-outlined" style="font-size:16px;">flag</span>Report
                                </button>
                                <form method="post" action="/Employee/ToggleSavedJob" style="margin:0;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="jobId" value="@job.JobID" />
                                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                                    <button type="submit" class="cta-btn secondary" style="font-size:0.83rem;padding:7px 12px;display:inline-flex;align-items:center;gap:4px;">
                                        <span class="material-symbols-outlined" style="font-size:16px;">@(savedJobIds.Contains(job.JobID ?? string.Empty) ? "bookmark" : "bookmark_border")</span>@(savedJobIds.Contains(job.JobID ?? string.Empty) ? "Saved" : "Save")
                                    </button>
                                </form>
                            }
                            else if (Context.Session.GetString("UserID") == null)
                            {
                                <a href="/Guest/Login" class="catalog-apply-btn" style="text-decoration:none;display:inline-flex;align-items:center;">Sign in to apply</a>
                            }
                        </div>
                    </article>
                }
            </div>
        }
        else
        {
            <p class="catalog-empty">No jobs match your current search. Try another keyword or clear the filters.</p>
        }

        @if (totalPages > 1)
        {
            <nav class="pager" aria-label="Job catalog pages">
                @if (page > 1)
                {
                    <a class="pager-step" href="@pageUrl(page - 1)" aria-label="Previous page"><span class="material-symbols-outlined" aria-hidden="true">chevron_left</span>Prev</a>
                }
                else
                {
                    <span class="pager-step disabled"><span class="material-symbols-outlined" aria-hidden="true">chevron_left</span>Prev</span>
                }

                @{
                    int windowStart = Math.Max(1, page - 1);
                    int windowEnd = Math.Min(totalPages, page + 1);
                }

                @if (windowStart > 1)
                {
                    <a href="@pageUrl(1)">1</a>
                    if (windowStart > 2)
                    {
                        <span class="ellipsis">…</span>
                    }
                }

                @for (int i = windowStart; i <= windowEnd; i++)
                {
                    if (i == page)
                    {
                        <span class="current" aria-current="page">@i</span>
                    }
                    else
                    {
                        <a href="@pageUrl(i)">@i</a>
                    }
                }

                @if (windowEnd < totalPages)
                {
                    if (windowEnd < totalPages - 1)
                    {
                        <span class="ellipsis">…</span>
                    }
                    <a href="@pageUrl(totalPages)">@totalPages</a>
                }

                @if (page < totalPages)
                {
                    <a class="pager-step" href="@pageUrl(page + 1)" aria-label="Next page">Next<span class="material-symbols-outlined" aria-hidden="true">chevron_right</span></a>
                }
                else
                {
                    <span class="pager-step disabled">Next<span class="material-symbols-outlined" aria-hidden="true">chevron_right</span></span>
                }
            </nav>
        }
    </section>

    <aside class="catalog-sidebar">
        <section class="card">
            <h3>Job Status</h3>
            <form id="status-filter-form" method="get" action="/Employee/JobCatalog">
                <input type="hidden" name="search" value="@search" />
                <input type="hidden" name="genreId" value="@selectedGenre" />
                <label style="display:flex; align-items:center; gap:10px; cursor:pointer; font-weight:600; padding:8px 0; color:var(--brand-800);">
                    <input type="checkbox" name="showActiveOnly" value="true" onchange="this.form.submit()" @(ViewBag.ShowActiveOnly == true ? "checked" : "") style="width:18px; height:18px; cursor:pointer;" />
                    <span>Show Active Jobs Only</span>
                </label>
            </form>
        </section>

        <section class="card">
            <h3>Genres</h3>
            <ul class="catalog-filter-list checkbox-list">
                <li>
                    <a class="@(string.IsNullOrWhiteSpace(selectedGenre) ? "active" : string.Empty)" href="/Employee/JobCatalog?search=@Uri.EscapeDataString(search)&showActiveOnly=@(ViewBag.ShowActiveOnly == true ? "true" : "false")">
                        <span>All genres</span>
                        <span class="fake-checkbox"></span>
                    </a>
                </li>
                @foreach (var genre in genres)
                {
                    <li>
                        <a class="@(string.Equals(selectedGenre, genre.GenreID, StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty)" href="/Employee/JobCatalog?search=@Uri.EscapeDataString(search)&genreId=@Uri.EscapeDataString(genre.GenreID ?? string.Empty)&showActiveOnly=@(ViewBag.ShowActiveOnly == true ? "true" : "false")">
                            <span>@genre.GenreTitle</span>
                            <span class="fake-checkbox"></span>
                        </a>
                    </li>
                }
            </ul>
        </section>
    </aside>
</main>

@if (TempData["Success"] != null)
{
    <div class="toast-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="toast-error">@TempData["Error"]</div>
}