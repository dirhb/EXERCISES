@*
    Views/Employee/JobHistory.cshtml
    Shows all jobs the employee has applied to.
    ViewBag.History = JobHistory object
*@

@using JobModels
@using JobModels.ViewModels
@{
    ViewBag.Title = "Job History";
    var history = ViewBag.History as JobHistory ?? new JobHistory();
    var applications = history.AppliedJobs ?? new List<AppliedJob>();
    var genres = history.Genres ?? new List<Genre>();
    var employers = history.Employers ?? new List<string>();

    // Map a stored status to a badge style + friendly label.
    // "Submitted" is shown to the candidate as "Pending".
    Func<string, (string css, string label)> statusBadge = s =>
    {
        string st = (s ?? "").Trim();
        if (string.Equals(st, "Accepted", StringComparison.OrdinalIgnoreCase)) return ("accepted", "Accepted");
        if (string.Equals(st, "Rejected", StringComparison.OrdinalIgnoreCase)) return ("rejected", "Rejected");
        return ("pending", "Pending");
    };
}

@section Styles {
    <link rel="stylesheet" href="~/css/JobHistory.css" />
}

<header class="page-header content-page-header job-history-page">
    <h1>Job History</h1>
    <p>All the jobs you have applied to, in one place.</p>
</header>

<main class="container job-history-page">
    <section class="left-col">
        <div class="card jobs-card">
            <h3>My Applications</h3>
            <div class="jobs-box" role="list">
                @if (applications.Any())
                {
                    @foreach (var item in applications)
                    {
                        var job = item.Job;
                        var badge = statusBadge(item.Status);
                        <div class="job-row" role="listitem" data-genre="@job.GenreID" data-status="@badge.label" style="display:flex; justify-content:space-between; align-items:center; gap:12px; padding:12px; border-bottom:1px solid var(--line);">
                            <div>
                                <strong>@job.JobTitle</strong>
                                <span class="app-status @badge.css">@badge.label</span><br />
                                <span style="color:var(--text-500);font-size:0.88rem;">@(job.EmployerName ?? "JobFind Employer") — @(job.CountryName ?? "Remote") — @(job.JobTypeName ?? "Not specified")</span>
                                @if (!string.IsNullOrWhiteSpace(item.AppliedAt))
                                {
                                    <span class="app-applied">Applied @item.AppliedAt</span>
                                }
                                @if (item.OfferedSalary != null && item.OfferedSalary.Value > 0)
                                {
                                    <span class="app-applied" style="color:var(--brand-700);font-weight:700;">Offered salary: <span class="money" data-usd="@item.OfferedSalary.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)">$@item.OfferedSalary.Value.ToString("N0")</span></span>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(job.EmployerID))
                            {
                                <a href="/Employee/Chat?partnerId=@job.EmployerID" class="cta-btn" style="padding:6px 12px; font-size:0.8rem; background:var(--brand-600); color:#fff; border-radius:var(--radius-sm); text-decoration:none;">
                                    Message
                                </a>
                            }
                        </div>
                    }
                }
                else
                {
                    <p style="color:var(--text-500);padding:12px;">You haven't applied to any jobs yet.</p>
                }
            </div>
        </div>
    </section>

    <aside class="right-col">
        @* Status filter *@
        <div class="card status-card">
            <h3>Status</h3>
            <div class="genres-list">
                <label><input type="radio" name="status" value="" checked /> All</label>
                <label><input type="radio" name="status" value="Pending" /> Pending</label>
                <label><input type="radio" name="status" value="Accepted" /> Accepted</label>
                <label><input type="radio" name="status" value="Rejected" /> Rejected</label>
            </div>
        </div>

        @* Genre filter *@
        <div class="card genres-card">
            <h3>Genres</h3>
            <div class="genres-list">
                @foreach (var genre in genres)
                {
                    <label>
                        <input type="checkbox" name="genre" value="@genre.GenreID" />
                        @genre.GenreTitle
                    </label>
                }
            </div>
        </div>
    </aside>
</main>

<div class="pagination">
    <button type="button">Page 1</button>
    <button type="button">Page 2</button>
    <button type="button">Page 3</button>
    <span class="ellipsis">…</span>
</div>
