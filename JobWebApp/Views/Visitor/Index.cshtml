@{
    ViewData["Title"] = "Home Page";
    Layout = "_Layout";
}
<section class="welcome-section">
    <h1>Welcome to JobFind</h1>
    <p>Your gateway to finding the perfect job. Browse thousands of opportunities or let us match you with jobs based on your skills and interests.</p>
</section>

<section class="stats-section">
    <div class="stat-box">
        <span class="stat-icon material-symbols-outlined">work</span>
        <h2 class="stat-number">10,000+</h2>
        <p class="stat-label">Active Jobs</p>
    </div>

    <div class="stat-box">
        <span class="stat-icon material-symbols-outlined">business</span>
        <h2 class="stat-number">5,000+</h2>
        <p class="stat-label">Companies</p>
    </div>

    <div class="stat-box">
        <span class="stat-icon material-symbols-outlined">star</span>
        <h2 class="stat-number">15,000+</h2>
        <p class="stat-label">Reviews</p>
    </div>

    <div class="stat-box">
        <span class="stat-icon material-symbols-outlined">group</span>
        <h2 class="stat-number">25,000+</h2>
        <p class="stat-label">Happy Users</p>
    </div>
</section>
<div style="display:flex">
<aside class="job">
    <div class="card jobs-card">
        <h3><span class="material-symbols-outlined">star</span> Jobs that fit your recent searches:</h3>
        <div class="jobs-box" aria-label="Jobs matching your searches">
            <div class="job-row">Software Engineer — Remote — Full time</div>
            <div class="job-row">Frontend Developer — React — Hybrid</div>
            <div class="job-row">Data Analyst — SQL / Python</div>
            <div class="job-row">UX Designer — Contract</div>
            <div class="job-row">Project Manager — Agile</div>
            <div class="job-row">QA Tester — Automation</div>
        </div>
    </div>
