
@*
    Views/Employer/PostJob.cshtml
    Form for employers to post a new job.
    Posts to EmployerController → PostJob (POST)
*@  
@model JobModels.ViewModels.PostJobViewModel
@{
    ViewBag.Title = "Post a Job";
    Layout = "_Layout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Register.css" />
}

<header class="page-header content-page-header">
    <h1>Post a Job</h1>
    <p>Fill in the details below to publish your job listing.</p>
</header>

<main class="container content-page" style="padding-top:24px">
    <section class="left-col">
        <div class="card">
            <form method="post" action="/Employer/PostAJob">
                @Html.AntiForgeryToken()

                <div class="acc-fields" style="display:grid;gap:16px">

                    <label style="display:flex;flex-direction:column;gap:6px;font-size:0.86rem;font-weight:600;color:var(--text-700);text-transform:uppercase;letter-spacing:0.02em">
                        Job Title
                        <input type="text" name="JobTitle" placeholder="e.g. Frontend Developer" required
                               style="font-family:inherit;font-size:0.95rem;font-weight:400;text-transform:none;letter-spacing:0;color:var(--text-900);background:var(--surface-2);border:1.5px solid var(--line);border-radius:var(--radius-sm);padding:10px 13px;outline:none;width:100%" />
                    </label>

                    <label style="display:flex;flex-direction:column;gap:6px;font-size:0.86rem;font-weight:600;color:var(--text-700);text-transform:uppercase;letter-spacing:0.02em">
                        Job Description
                        <textarea name="JobDescription" rows="5" placeholder="Describe the role, responsibilities, and requirements..." required
                                  style="font-family:inherit;font-size:0.95rem;font-weight:400;text-transform:none;letter-spacing:0;color:var(--text-900);background:var(--surface-2);border:1.5px solid var(--line);border-radius:var(--radius-sm);padding:10px 13px;outline:none;width:100%;resize:vertical"></textarea>
                    </label>

                    <label style="display:flex;flex-direction:column;gap:6px;font-size:0.86rem;font-weight:600;color:var(--text-700);text-transform:uppercase;letter-spacing:0.02em">
                        Job Type
                        <select name="JobType" required style="font-family:inherit;font-size:0.95rem;font-weight:400;text-transform:none;color:var(--text-900);background:var(--surface-2);border:1.5px solid var(--line);border-radius:var(--radius-sm);padding:10px 13px;outline:none;width:100%">
                            <option value="" disabled selected>Choose a job type</option>
                            @foreach (JobType jobType in Model.JobTypes)
                            {
                                <option value="@jobType.JobTypeID">@jobType.JobTypeName</option>
                            }
                        </select>
                    </label>

                    <label style="display:flex;flex-direction:column;gap:6px;font-size:
                    0.86rem;font-weight:600;color:var(--text-700);text-transform:uppercase;
                    letter-spacing:0.02em">
                        Genre
                        <select name="GenreID" required 
                            style="font-family:inherit;font-size:0.95rem;font-weight:400;
                            text-transform:none;color:var(--text-900);
                            background:var(--surface-2);border:1.5px solid var(--line);
                            border-radius:var(--radius-sm);
                            padding:10px 13px;outline:none;width:100%">
                            <option value="" disabled selected>Choose a genre</option>
                            @foreach (Genre genre in Model.Genres)
                            {
                                <option value="@genre.GenreID">@genre.GenreTitle</option>
                            }
                        </select>
                    </label>

                    <label style="display:flex;flex-direction:column;gap:6px;font-size:0.86rem;font-weight:600;color:var(--text-700);text-transform:uppercase;letter-spacing:0.02em">
                        Search Keywords / Filters
                        <input type="text" name="JobFilter" placeholder="e.g. junior, SQL, remote, customer service"
                               style="font-family:inherit;font-size:0.95rem;font-weight:400;text-transform:none;letter-spacing:0;color:var(--text-900);background:var(--surface-2);border:1.5px solid var(--line);border-radius:var(--radius-sm);padding:10px 13px;outline:none;width:100%" />
                    </label>

                    <div style="display:flex;flex-direction:column;gap:6px;position:relative;">
                        <span style="font-size:0.86rem;font-weight:600;color:var(--text-700);text-transform:uppercase;letter-spacing:0.02em">Location (Country)</span>
                        <input type="text" id="country-search-input" placeholder="Type to search country (e.g. Israel, United States)..." autocomplete="off" required
                               style="font-family:inherit;font-size:0.95rem;font-weight:400;text-transform:none;letter-spacing:0;color:var(--text-900);background:var(--surface-2);border:1.5px solid var(--line);border-radius:var(--radius-sm);padding:10px 13px;outline:none;width:100%" />
                        <input type="hidden" name="CountryID" id="country-id-hidden" required />
                        <div id="country-suggestions" style="display:none; position:absolute; top:100%; left:0; right:0; z-index:1000; max-height:200px; overflow-y:auto; background:var(--surface); border:1.5px solid var(--line); border-radius:var(--radius-sm); box-shadow:var(--shadow-md); margin-top:4px;"></div>
                    </div>

                    <button type="submit" class="auth-submit" style="margin-top:8px">
                        Publish Job
                    </button>
                </div>

            </form>
        </div>
    </section>

    <aside class="right-col">
        <div class="card">
            <h3>Tips for a great listing</h3>
            <ul class="popular-list">
                <li>Be specific about the role and responsibilities</li>
                <li>Mention salary range if possible</li>
                <li>List required and preferred skills separately</li>
                <li>Include remote/hybrid/on-site info</li>
            </ul>
        </div>
    </aside>
</main>

@if (TempData["Success"] != null)
{
    <div style="position:fixed;bottom:24px;right:24px;background:var(--color-background-success);color:var(--color-text-success);padding:12px 20px;border-radius:10px;box-shadow:var(--shadow-md);font-size:0.93rem;">
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div style="position:fixed;bottom:24px;right:24px;background:var(--color-background-danger);color:var(--color-text-danger);padding:12px 20px;border-radius:10px;box-shadow:var(--shadow-md);font-size:0.93rem;">
        @TempData["Error"]
    </div>
}

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", async () => {
            const form = document.querySelector("form[action='/Employer/PostAJob']");
            const searchInput = document.getElementById("country-search-input");
            const hiddenInput = document.getElementById("country-id-hidden");
            const suggestionsDiv = document.getElementById("country-suggestions");
            
            let countries = [];
            try {
                const res = await fetch("/Guest/GetAllCountries");
                countries = await res.json();
            } catch (err) {
                console.error("Failed to load countries", err);
            }

            searchInput.addEventListener("input", () => {
                const query = searchInput.value.toLowerCase().trim();
                suggestionsDiv.innerHTML = "";
                
                if (!query) {
                    suggestionsDiv.style.display = "none";
                    hiddenInput.value = "";
                    return;
                }

                const matches = countries.filter(c => (c.countryName || "").toLowerCase().includes(query));
                if (matches.length === 0) {
                    suggestionsDiv.style.display = "none";
                    return;
                }

                suggestionsDiv.style.display = "block";
                matches.forEach(c => {
                    const item = document.createElement("div");
                    item.textContent = c.countryName;
                    item.style.padding = "10px 12px";
                    item.style.cursor = "pointer";
                    item.style.borderBottom = "1px solid var(--line)";
                    item.addEventListener("mouseover", () => item.style.background = "var(--surface-2)");
                    item.addEventListener("mouseout", () => item.style.background = "");
                    item.addEventListener("click", () => {
                        searchInput.value = c.countryName;
                        hiddenInput.value = c.countryID;
                        suggestionsDiv.style.display = "none";
                    });
                    suggestionsDiv.appendChild(item);
                });
            });

            // Close suggestions dropdown when clicking outside
            document.addEventListener("click", (e) => {
                if (e.target !== searchInput && e.target !== suggestionsDiv) {
                    suggestionsDiv.style.display = "none";
                }
            });

            // Validate that country was selected from list before form submit
            if (form) {
                form.addEventListener("submit", (e) => {
                    if (!hiddenInput.value) {
                        e.preventDefault();
                        searchInput.style.borderColor = "#d63031";
                        searchInput.placeholder = "Please select a country from the dropdown list";
                        searchInput.focus();
                        alert("Please select a country from the suggestions list.");
                    }
                });
            }
        });
    </script>
}

