@*
    Views/Admin/Notify.cshtml
    Admin view — send notifications to all users or search for a specific user.
*@

@using JobModels
@{
    ViewBag.Title = "Send Notifications";
    var users = ViewBag.Users as List<User> ?? new List<User>();
    string userSearch = ViewBag.UserSearch as string ?? string.Empty;
}

@section Styles {
    <link rel="stylesheet" href="~/css/Register.css" />
}

<header class="page-header content-page-header">
    <h1>Notify Users</h1>
    <p>Send a broadcast to all users or target a specific user.</p>
</header>

<main class="container content-page" style="padding-top:24px">
    <section class="left-col">

        @* Broadcast to all *@
        <div class="card" style="margin-bottom:20px">
            <h3>Broadcast to All Users</h3>
            <form method="post" action="/Admin/SendNotification" style="display:grid;gap:12px;margin-top:12px;">
                @Html.AntiForgeryToken()
                <label style="display:flex;flex-direction:column;gap:6px;font-size:0.86rem;font-weight:600;color:var(--text-700);">
                    Message
                    <textarea name="text" rows="4" placeholder="Type your notification message..."
                              style="font-family:inherit;font-size:0.95rem;font-weight:400;color:var(--text-900);background:var(--surface-2);border:1.5px solid var(--line);border-radius:var(--radius-sm);padding:10px 13px;outline:none;resize:vertical;"></textarea>
                </label>
                <button type="submit" class="auth-submit" style="width:auto;padding:10px 24px;">Send to All</button>
            </form>
        </div>

        @* User search *@
        <div class="card">
            <h3>Search & Notify Specific User</h3>
            <form method="get" action="/Admin/Notify" style="display:flex;gap:10px;margin-top:12px;flex-wrap:wrap;">
                <input type="search" name="userSearch" value="@userSearch" placeholder="Search by name, username, or email..."
                       style="flex:1;min-width:200px;font-family:inherit;font-size:0.95rem;color:var(--text-900);background:var(--surface-2);border:1.5px solid var(--line);border-radius:var(--radius-sm);padding:10px 13px;outline:none;" />
                <button type="submit" style="background:var(--brand-600);color:#fff;border:none;border-radius:var(--radius-sm);padding:10px 18px;font-weight:600;cursor:pointer;">Search</button>
            </form>

            @if (!string.IsNullOrEmpty(userSearch))
            {
                <div style="margin-top:16px;">
                    @if (users.Any())
                    {
                        @foreach (var user in users)
                        {
                            <div style="display:flex;justify-content:space-between;align-items:center;padding:12px;border-bottom:1px solid var(--line);gap:12px;">
                                <div>
                                    <strong>@user.FirstName @user.LastName</strong><br />
                                    <span style="color:var(--text-500);font-size:0.85rem;">@@@user.UserName — @user.Email</span>
                                </div>
                                <form method="post" action="/Admin/SendNotificationToUser" style="display:flex;gap:8px;align-items:center;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" value="@user.UserID" />
                                    <input type="text" name="text" placeholder="Message..."
                                           style="font-size:0.88rem;padding:6px 10px;border:1px solid var(--line);border-radius:var(--radius-sm);background:var(--surface-2);color:var(--text-900);outline:none;" />
                                    <button type="submit" style="background:var(--brand-600);color:#fff;border:none;border-radius:var(--radius-sm);padding:7px 14px;font-size:0.85rem;font-weight:600;cursor:pointer;">Send</button>
                                </form>
                            </div>
                        }
                    }
                    else
                    {
                        <p style="color:var(--text-500);padding:12px;">No users found for "@userSearch".</p>
                    }
                </div>
            }
        </div>
    </section>

    <aside class="right-col">
        <div class="card">
            <h3>Admin Actions</h3>
            <ul class="popular-list">
                <li><a href="/Admin/Home">Manage Jobs</a></li>
                <li><a href="/Admin/Applications">Applications</a></li>
                <li><a href="/Admin/Notify">Send Notifications</a></li>
                <li><a href="/Guest/Logout" style="color:var(--color-text-danger)">Logout</a></li>
            </ul>
        </div>
    </aside>
</main>

@if (TempData["Success"] != null)
{
    <div class="toast-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="toast-error">@TempData["Error"]</div>
}
