@*
    Views/Guest/ForgotPassword.cshtml
    Simple password reset: verify email + username, then set a new password.
*@

@{
    ViewBag.Title = "Reset Password";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Register.css" />
}

<main class="auth-wrapper">
    <div class="auth-panel-left">
        <div class="auth-brand">
            <div class="auth-logo-wrap">
                <img src="~/images/JobFind_Logo.png" alt="JobFind logo" class="auth-logo" />
            </div>
            <h1>Reset your password.</h1>
            <p>Confirm your email and username to set a new password for your JobFind account.</p>
        </div>
    </div>

    <div class="auth-panel-right">
        <div class="auth-card">
            @if (TempData["Error"] != null)
            {
                <div style="background:var(--color-background-danger);color:var(--color-text-danger);padding:10px 14px;border-radius:8px;margin-bottom:16px;font-size:0.9rem;">
                    @TempData["Error"]
                </div>
            }

            <form class="auth-form" id="forgot-form" method="post" action="/Guest/ForgotPassword">
                <h2>Forgot password</h2>
                <p class="auth-subtitle">Verify your identity, then choose a new password.</p>

                <div class="auth-field">
                    <label for="fp-email">Email</label>
                    <div class="auth-input-wrap">
                        <span class="material-symbols-outlined">mail</span>
                        <input type="text" id="fp-email" name="email" placeholder="Your account email" />
                    </div>
                </div>

                <div class="auth-field">
                    <label for="fp-username">Username</label>
                    <div class="auth-input-wrap">
                        <span class="material-symbols-outlined">badge</span>
                        <input type="text" id="fp-username" name="username" placeholder="Your username" />
                    </div>
                </div>

                <div class="auth-field">
                    <label for="fp-password">New Password</label>
                    <div class="auth-input-wrap">
                        <span class="material-symbols-outlined">lock</span>
                        <input type="password" id="fp-password" name="newPassword" placeholder="Create a new password" />
                        <button type="button" class="toggle-pw" aria-label="Toggle password">
                            <span class="material-symbols-outlined">visibility</span>
                        </button>
                    </div>
                </div>

                <div class="auth-field">
                    <label for="fp-confirm">Confirm New Password</label>
                    <div class="auth-input-wrap">
                        <span class="material-symbols-outlined">lock</span>
                        <input type="password" id="fp-confirm" name="confirmPassword" placeholder="Re-enter the new password" />
                    </div>
                </div>

                <button type="submit" class="auth-submit">Reset Password</button>

                <p class="auth-subtitle" style="margin-top:14px;">
                    <a href="/Guest/Login?tab=signin" style="color:var(--brand-600);">Back to sign in</a>
                </p>
            </form>
        </div>
    </div>
</main>
